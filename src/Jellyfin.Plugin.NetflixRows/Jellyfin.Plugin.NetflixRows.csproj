<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Jellyfin.Plugin.NetflixRows</RootNamespace>
    <AssemblyName>Jellyfin.Plugin.NetflixRows</AssemblyName>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
    <WarningsAsErrors>false</WarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <!-- Provides MediaBrowser.Controller / MediaBrowser.Model / MediaBrowser.Common -->
    <PackageReference Include="Jellyfin.Controller" Version="10.10.3" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Configuration\configPage.html" />
    <EmbeddedResource Include="Configuration\configPage.js" />
    <EmbeddedResource Include="WebInjection\wwwroot\netflixRows.js" />
    <EmbeddedResource Include="WebInjection\wwwroot\netflixRows.css" />
  </ItemGroup>

</Project>
